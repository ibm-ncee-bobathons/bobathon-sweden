# watsonx Orchestrate Environment Configuration
# Copy this file to .env and fill in your actual values

# watsonx Orchestrate API Key
# Get this from your watsonx Orchestrate environment:
# - For IBM Cloud SaaS: IBM Cloud > Manage > Access (IAM) > API keys
# - For Developer Edition: Generated during local setup
WXO_API_KEY=your_api_key_here

# watsonx Orchestrate Service Instance URL
# - For IBM Cloud SaaS: https://your-instance.watson-orchestrate.ibm.com
# - For Developer Edition: http://localhost:3000
WXO_SERVICE_URL=https://your-instance.watson-orchestrate.ibm.com

# Optional: Environment Name (for reference only)
WXO_ENVIRONMENT_NAME=my-wxo-environment

# Optional: Working Directory for MCP Server
# This should be the absolute path to your project directory
# Example: /Users/username/projects/wxo-agentic-workflow
WXO_MCP_WORKING_DIRECTORY=/absolute/path/to/your/project

# Optional: Debug Mode (set to "true" to enable debug logging)
WXO_MCP_DEBUG=false